APP_ENV=development
PORT=4000

# Postgres (the dev DB runs in Docker on port 5433)
DATABASE_URL=postgresql://ksn_admin:ksn_secret_dev@localhost:5433/sehat_nusantara?sslmode=disable

# Use a long random string in production (min 32 chars)
# Generate with: openssl rand -base64 48
JWT_SECRET=dev-super-secret-change-me-please-32chars-min

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Seed admin (created on first boot; change the password after first login)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sehatnusantara.id
ADMIN_PASSWORD=Admin#12345

# Directory for uploaded media files (relative to working directory)
UPLOAD_DIR=uploads

# ─── Production overrides ────────────────────────────────────────────────────
# Copy the block below into your server environment and fill in real values.
# NEVER commit real production values here.
#
# APP_ENV=production
# DATABASE_URL=postgresql://user:password@db-host:5432/sehat_nusantara?sslmode=require
# JWT_SECRET=<generate: openssl rand -base64 48>
# CORS_ORIGINS=https://sehatnusantara.id,https://www.sehatnusantara.id
# ADMIN_EMAIL=admin@sehatnusantara.id
# ADMIN_PASSWORD=<strong password, 16+ chars>
# UPLOAD_DIR=/var/app/uploads
